APP_PORT=8080
APP_NAME="Observatório de Projetos Integradores"

DB_HOST=db
DB_PORT=3306
DB_NAME=opi
DB_USER=opi_user
DB_PASSWORD=opi_secret
DB_ROOT_PASSWORD=root_secret

# Max attachment size per file in bytes (default: 1 GiB)
UPLOAD_MAX_BYTES=1073741824

